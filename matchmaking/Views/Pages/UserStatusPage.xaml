<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.Views.Pages.UserStatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:matchmaking.Converters"
    Background="#F0F2F5">

    <Page.Resources>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
        <converters:MatchStatusToColorConverter x:Key="StatusToColor"/>
        <converters:MatchStatusToTextConverter  x:Key="StatusToText"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="#333333"/>
            <Setter Property="Padding"          Value="4,0"/>
        </Style>
        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius"     Value="20"/>
            <Setter Property="Padding"          Value="16,6"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>

        <!-- ── Job Card DataTemplate ──────────────────────────────────────── -->
        <DataTemplate x:Key="JobCardTemplate">
            <Border Background="White" CornerRadius="10" Padding="20"
                    BorderBrush="#E1E1E1" BorderThickness="1" Margin="0,0,0,0">
                <StackPanel Spacing="6">

                    <!-- Title + status badge -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding TruncatedDescription}"
                                   FontWeight="Bold" FontSize="15"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1"
                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                CornerRadius="10" Padding="9,3"
                                VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <!-- Company -->
                    <TextBlock Text="{Binding CompanyName}"
                               FontSize="13" FontWeight="SemiBold" Foreground="#505050"/>

                    <!-- Applied date -->
                    <TextBlock Text="{Binding FormattedDate}"
                               FontSize="12" Foreground="#A0A0A0"/>

                    <!-- Compatibility score -->
                    <TextBlock Text="{Binding FormattedScore}"
                               FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"
                               Margin="0,2,0,0"/>

                    <!-- Feedback (only when present) -->
                    <TextBlock Text="{Binding FeedbackMessage}"
                               FontSize="12" Foreground="#757575"
                               TextWrapping="Wrap" FontStyle="Italic" Margin="0,2,0,0"
                               Visibility="{Binding HasFeedback, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <Button Content="View Job Details"
                                Tag="{Binding}"
                                FontSize="12" Padding="12,6" CornerRadius="6"
                                Click="ViewJobDetails_Click"/>
                        <Button Content="View Skill Gap"
                                Tag="{Binding}"
                                FontSize="12" Padding="12,6" CornerRadius="6"
                                Click="ViewSkillGap_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ── Sidebar: Skill-to-Improve row DataTemplate ─────────────────── -->
        <DataTemplate x:Key="UnderscoredSkillTemplate">
            <Grid Margin="0,0,0,2" ColumnDefinitions="80,*,30">
                <TextBlock Grid.Column="0"
                           Text="{Binding SkillName}"
                           FontSize="12" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <ProgressBar Grid.Column="1"
                             Value="{Binding UserScore}" Maximum="100"
                             Foreground="Black" VerticalAlignment="Center"
                             Margin="4,0"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding UserScore}"
                           FontSize="12" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </DataTemplate>

        <!-- ── Sidebar: Missing-Skill row DataTemplate ────────────────────── -->
        <DataTemplate x:Key="MissingSkillSidebarTemplate">
            <TextBlock Text="{Binding SkillName}"
                       FontSize="12" Foreground="#D32F2F" TextWrapping="Wrap"/>
        </DataTemplate>

    </Page.Resources>

    <Grid RowDefinitions="56,*">

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="Black" BorderThickness="0,0,0,2">
            <Grid Padding="24,0" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Source="/Assets/div.nav-logo-mark.png" Width="28" Height="28" VerticalAlignment="Center"/>
                    <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="Tinder" Foreground="Black"/>
                        <Run Text="Jobs"   Foreground="#888888"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="28" VerticalAlignment="Center">
                    <Button Content="Recommendations" Style="{StaticResource NavButtonStyle}"/>
                    <Border Background="Black" CornerRadius="14" Padding="14,5">
                        <TextBlock Text="My Status" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                    </Border>
                    <Button Content="Chat" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <PersonPicture Grid.Column="2" Width="34" Height="34" Initials="AJ" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" ColumnDefinitions="*,290" Padding="28,20,16,20">

            <!-- ── Left: Application Status ─────────────────────────────────── -->
            <Grid Grid.Column="0" Padding="0,0,16,0" RowDefinitions="Auto,Auto,*">

                <!-- Title + buttons -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="My Application Status" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Spacing="8">
                        <Button x:Name="SkillInsightsButton" Content="Skill Insights"
                                Click="SkillInsightsButton_Click"/>
                        <Button x:Name="RefreshButton" Content="Refresh"
                                Click="RefreshButton_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Filter Pills -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                    <Button x:Name="FilterAll"      Content="All"      Tag="All"      Click="Filter_Click" Style="{StaticResource PillButtonStyle}"/>
                    <Button x:Name="FilterApplied"  Content="Applied"  Tag="Applied"  Click="Filter_Click" Style="{StaticResource PillButtonStyle}"/>
                    <Button x:Name="FilterAccepted" Content="Accepted" Tag="Accepted" Click="Filter_Click" Style="{StaticResource PillButtonStyle}"/>
                    <Button x:Name="FilterRejected" Content="Rejected" Tag="Rejected" Click="Filter_Click" Style="{StaticResource PillButtonStyle}"/>
                </StackPanel>

                <!-- States layer -->
                <Grid Grid.Row="2">

                    <!-- Loading spinner -->
                    <ProgressRing x:Name="LoadingRing" IsActive="True"
                                  Width="48" Height="48"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Error -->
                    <TextBlock Text="Unable to load your applications. Please try again."
                               Foreground="Red" TextAlignment="Center" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding EmptyMessage}"
                                   FontSize="14" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
                        <Button x:Name="GoToRecommendationsButton"
                                Content="Go to Recommendations"
                                HorizontalAlignment="Center" Margin="0,8,0,0"
                                Visibility="{Binding ShowGoToRecommendations, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>

                    <!-- Cards -->
                    <ScrollViewer Visibility="{Binding ShowCards, Converter={StaticResource BoolToVisibility}}">
                        <ItemsRepeater ItemsSource="{Binding FilteredJobs}"
                                       ItemTemplate="{StaticResource JobCardTemplate}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MaximumRowsOrColumns="2"
                                                   MinColumnSpacing="16"
                                                   MinRowSpacing="16"
                                                   ItemsStretch="Fill"/>
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>
                    </ScrollViewer>

                </Grid>
            </Grid>

            <!-- ── Right: Skill Gap Sidebar ──────────────────────────────────── -->
            <Border Grid.Column="1" Background="White" CornerRadius="8"
                    Padding="16" VerticalAlignment="Top"
                    BorderBrush="Black" BorderThickness="0,3,0,0">
                <StackPanel Spacing="10">

                    <TextBlock Text="Skill Gap Analysis" FontWeight="Bold" FontSize="15" Foreground="Black"/>

                    <!-- Summary text when no gap data -->
                    <TextBlock Text="{Binding SkillGapMessage}"
                               Foreground="#757575" FontSize="12" TextWrapping="Wrap"
                               Visibility="{Binding HasSkillGapMessage, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Skill data panel -->
                    <StackPanel Spacing="8"
                                Visibility="{Binding ShowSkillData, Converter={StaticResource BoolToVisibility}}">

                        <TextBlock Text="{Binding SkillGapSummaryText}"
                                   FontSize="12" Foreground="DarkOrange" Margin="0,0,0,4"/>

                        <!-- Skills to Improve -->
                        <StackPanel Spacing="4"
                                    Visibility="{Binding HasUnderscoredSkills, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Skills to Improve:"
                                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2"/>
                            <ItemsControl ItemsSource="{Binding UnderscoredSkills}"
                                          ItemTemplate="{StaticResource UnderscoredSkillTemplate}"/>
                        </StackPanel>

                        <!-- Missing Skills -->
                        <StackPanel Spacing="4" Margin="0,8,0,0"
                                    Visibility="{Binding HasSidebarMissingSkills, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Missing Skills:"
                                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2"/>
                            <ItemsControl ItemsSource="{Binding SkillGapMissingSkills}"
                                          ItemTemplate="{StaticResource MissingSkillSidebarTemplate}"/>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Page>
